generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model account_snapshots {
  id                   BigInt   @id @default(autoincrement())
  ts                   DateTime @default(now()) @db.Timestamptz(6)
  equity               Decimal  @db.Decimal(18, 4)
  balance              Decimal  @db.Decimal(18, 4)
  drawdown_pct         Decimal  @db.Decimal(6, 4)
  open_positions_count Int

  @@index([ts(sort: Desc)], map: "idx_snapshots_ts")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model claude_decisions {
  id              BigInt   @id @default(autoincrement())
  trade_id        BigInt?
  symbol          String
  context_json    Json
  decision        String
  confidence      Int
  reasoning       String
  risk_adjustment Decimal  @db.Decimal(4, 2)
  ts              DateTime @default(now()) @db.Timestamptz(6)
  trades          trades?  @relation(fields: [trade_id], references: [id], onUpdate: NoAction)

  @@index([ts(sort: Desc)], map: "idx_claude_ts")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model model_performance {
  id                      BigInt   @id @default(autoincrement())
  model_name              String
  version                 String
  ts                      DateTime @default(now()) @db.Timestamptz(6)
  accuracy                Decimal? @db.Decimal(6, 4)
  loss                    Decimal? @db.Decimal(12, 6)
  sharpe                  Decimal? @db.Decimal(8, 4)
  total_trades_trained_on Int?

  @@index([model_name, ts(sort: Desc)], map: "idx_model_perf_ts")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model signals {
  id               BigInt   @id @default(autoincrement())
  symbol           String
  timeframe        String
  signal_type      String
  smc_zone         String?
  confidence       Int?
  news_flag        Boolean  @default(false)
  kill_zone_active Boolean  @default(false)
  ts               DateTime @default(now()) @db.Timestamptz(6)

  @@index([symbol, ts(sort: Desc)], map: "idx_signals_sym_ts")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model trades {
  id                      BigInt             @id @default(autoincrement())
  mt5_ticket              BigInt?            @unique
  symbol                  String
  direction               String
  entry_price             Decimal            @db.Decimal(18, 8)
  exit_price              Decimal?           @db.Decimal(18, 8)
  lot_size                Decimal            @db.Decimal(10, 4)
  sl                      Decimal            @db.Decimal(18, 8)
  tp                      Decimal            @db.Decimal(18, 8)
  pnl                     Decimal?           @db.Decimal(18, 4)
  r_r_achieved            Decimal?           @db.Decimal(8, 4)
  open_time               DateTime           @db.Timestamptz(6)
  close_time              DateTime?          @db.Timestamptz(6)
  close_reason            String?
  signal_confluence_score Int?
  claude_decision         String?
  claude_confidence       Int?
  claude_reasoning        String?
  created_at              DateTime           @default(now()) @db.Timestamptz(6)
  claude_decisions        claude_decisions[]

  @@index([close_time(sort: Desc)], map: "idx_trades_close")
  @@index([symbol, open_time(sort: Desc)], map: "idx_trades_symbol_open")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model weekly_debriefs {
  id                    BigInt   @id @default(autoincrement())
  week_start            DateTime @unique @db.Date
  markdown              String
  param_recommendations Json?
  trades_count          Int?
  net_pnl               Decimal? @db.Decimal(18, 4)
  win_rate              Decimal? @db.Decimal(5, 4)
  created_at            DateTime @default(now()) @db.Timestamptz(6)
}
